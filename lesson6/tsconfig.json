{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["DOM", "ESNext"],
    "jsx": "react-jsx",
    "strict": true,
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@products/*": ["src/feature/products/*"],
      "@cart/*": ["src/feature/cart/*"],
      "@shared/*": ["src/shared/*"]
    }
  },
  "include": ["src"]
}
